---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const publications = (await getCollection('publications'))
  .sort((a, b) => b.data.year - a.data.year);

const published = publications.filter(p => p.data.status === 'published');
const inProgress = publications.filter(p => p.data.status === 'in-progress');
---

<BaseLayout title="Publications — Your Name" description="Research publications and academic work.">
  <section class="max-w-5xl mx-auto px-6 py-16">
    <p class="section-label mb-4">Research</p>
    <h1 class="font-display text-5xl font-extrabold mb-4">Publications</h1>
    <p class="font-body text-lg opacity-60 max-w-xl mb-16">
      Peer-reviewed work and research contributions. More coming soon.
    </p>

    <!-- Published -->
    {published.length > 0 && (
      <div class="mb-16">
        <h2 class="font-display text-sm font-semibold uppercase tracking-widest opacity-40 mb-6">Published</h2>
        <div class="grid gap-4">
          {published.map((pub, i) => (
            <div class="p-6 border animate-on-scroll" style={`border-color: var(--border); animation-delay: ${i * 0.08}s;`}>
              <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-3">
                <h3 class="font-display text-lg font-bold leading-snug flex-1">{pub.data.title}</h3>
                <span class="font-mono text-xs opacity-40 shrink-0">{pub.data.year}</span>
              </div>
              <p class="font-mono text-xs opacity-50 mb-3">{pub.data.authors.join(', ')}</p>
              <p class="font-body text-sm opacity-60 mb-4" style="color: var(--royal);" class="dark:text-blue-400">
                {pub.data.venue}
              </p>

              <!-- Abstract toggle -->
              <details class="group">
                <summary class="font-mono text-xs cursor-pointer opacity-40 hover:opacity-100 transition-opacity select-none">
                  Abstract ↓
                </summary>
                <p class="font-body text-sm leading-relaxed opacity-60 mt-3 pl-0 border-l-2 pl-4"
                   style="border-color: var(--amber);">
                  {pub.data.abstract}
                </p>
              </details>

              {pub.data.url && (
                <a href={pub.data.url} target="_blank" rel="noopener"
                   class="inline-flex items-center gap-1 font-mono text-xs mt-4 opacity-50 hover:opacity-100 transition-opacity">
                  Read paper →
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- In Progress -->
    {inProgress.length > 0 && (
      <div>
        <h2 class="font-display text-sm font-semibold uppercase tracking-widest opacity-40 mb-6">In Progress</h2>
        <div class="grid gap-4">
          {inProgress.map((pub, i) => (
            <div class="p-6 border border-dashed animate-on-scroll" style={`border-color: var(--border); animation-delay: ${i * 0.08}s; opacity: 0.7;`}>
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="font-display text-lg font-bold leading-snug flex-1">{pub.data.title}</h3>
                <span class="tag bg-blush text-rose-600 dark:bg-blush/10 dark:text-rose-300 border-blush shrink-0">
                  In review
                </span>
              </div>
              <p class="font-mono text-xs opacity-50">{pub.data.authors.join(', ')}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Empty state -->
    {publications.length === 0 && (
      <div class="py-24 text-center border border-dashed" style="border-color: var(--border);">
        <p class="font-mono text-xs opacity-30">Publications loading — check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>

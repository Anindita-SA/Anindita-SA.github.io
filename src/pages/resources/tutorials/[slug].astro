---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  return tutorials.map(tutorial => ({
    params: { slug: tutorial.slug },
    props: { tutorial },
  }));
}

interface Props {
  tutorial: CollectionEntry<'tutorials'>;
}

const { tutorial } = Astro.props;
const { Content } = await tutorial.render();

const difficultyColor: Record<string, string> = {
  Beginner: 'background-color: rgba(0,35,102,0.1); color: #002366; border: 1px solid rgba(0,35,102,0.2);',
  Intermediate: 'background-color: rgba(252,186,4,0.15); color: #92400e; border: 1px solid rgba(252,186,4,0.3);',
  Advanced: 'background-color: rgba(253,21,27,0.1); color: #FD151B; border: 1px solid rgba(253,21,27,0.2);',
};
---

<BaseLayout title={`${tutorial.data.title} — Tutorials`} description={tutorial.data.description}>
  <article class="max-w-3xl mx-auto px-6 py-16">

    <a href="/resources/tutorials" class="font-mono text-xs opacity-40 hover:opacity-100 transition-opacity inline-flex items-center gap-2 mb-12">
      ← All tutorials
    </a>

    <div class="mb-12">
      <div class="flex flex-wrap gap-2 mb-6">
        {tutorial.data.tags.map((tag: string) => (
          <span class="tag" style="background-color: var(--bg-surface); border: 1px solid var(--border);">{tag}</span>
        ))}
        <span class="tag" style={difficultyColor[tutorial.data.difficulty]}>
          {tutorial.data.difficulty}
        </span>
        {tutorial.data.duration && (
          <span class="font-mono text-xs opacity-40 self-center ml-1">{tutorial.data.duration}</span>
        )}
      </div>

      <h1 class="font-display text-4xl md:text-5xl font-extrabold leading-tight mb-4">
        {tutorial.data.title}
      </h1>
      <p class="font-body text-xl opacity-60 leading-relaxed">{tutorial.data.description}</p>
    </div>

    <div class="flex gap-1 mb-12">
      <div class="h-1 w-12" style="background: var(--royal);"></div>
      <div class="h-1 w-4" style="background: var(--crimson);"></div>
      <div class="h-1 w-2" style="background: var(--amber);"></div>
    </div>

    <div class="prose-content">
      <Content />
    </div>

  </article>
</BaseLayout>

<style>
  
  .prose-content :global(h2) {
    font-family: 'Graviton', 'Google Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }
  .prose-content :global(h3) {
    font-family: 'Graviton', 'Google Sans', sans-serif;
    font-size: 1 rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }
  .prose-content :global(p) {
    line-height: 1.8;
    margin-bottom: 1.25rem;
    opacity: 0.8;
  }
  .prose-content :global(ul) {
    list-style: disc;
    margin-bottom: 1.5rem;
    padding-left: 1.75rem;
  }
  .prose-content :global(ol) {
    list-style: decimal;
    margin-bottom: 1.5rem;
    padding-left: 1.75rem;
  }
  .prose-content :global(li) {
    margin-bottom: 1rem;
    opacity: 0.8;
    line-height: 1.7;
    display: list-item;
  }
  .prose-content :global(pre) {
    background-color: #1a1a2e !important;
    border: 1px solid #2d2d4e;
    padding: 1.5rem;
    margin: 2rem 0;
    overflow-x: auto;
    border-radius: 2px;
    position: relative;
  }
  .prose-content :global(pre code) {
    color: #e2e8f0 !important;
    background: none !important;
    padding: 0 !important;
    font-size: 0.85rem;
    line-height: 1.7;
  }
  .prose-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
  }
  .prose-content :global(p code) {
    background-color: var(--bg-surface);
    color: var(--crimson);
    padding: 0.125rem 0.375rem;
    border-radius: 2px;
    border: 1px solid var(--border);
  }
  .prose-content :global(strong) {
    font-weight: 600;
    color: var(--text-primary);
  }
  .prose-content :global(blockquote) {
    border-left: 3px solid var(--amber);
    padding-left: 1.5rem;
    margin: 2rem 0;
    opacity: 0.7;
    font-style: italic;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.625rem;
    border-radius: 2px;
    font-size: 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

</style>
<script is:inline>
  document.querySelectorAll('.prose-content pre').forEach(pre => {
    const button = document.createElement('button');
    button.textContent = 'Copy';
    button.style.cssText = `
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
      padding: 0.25rem 0.75rem;
      background: transparent;
      color: #94a3b8;
      border: 1px solid #334155;
      cursor: pointer;
      transition: all 0.2s;
    `;
    button.addEventListener('mouseenter', () => button.style.color = '#e2e8f0');
    button.addEventListener('mouseleave', () => button.style.color = '#94a3b8');
    button.addEventListener('click', () => {
      const code = pre.querySelector('code');
      navigator.clipboard.writeText(code.innerText).then(() => {
        button.textContent = 'Copied!';
        button.style.color = '#FCBA04';
        setTimeout(() => {
          button.textContent = 'Copy';
          button.style.color = '#94a3b8';
        }, 2000);
      });
    });
    pre.style.position = 'relative';
    pre.appendChild(button);
  });
</script>
---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const tagClass: Record<string, string> = {
  Renewables: 'tag-renewables',
  Electronics: 'tag-electronics',
  'Product Design': 'tag-product',
  Research: 'tag-research',
};
---

<BaseLayout title="Anindita Sarker Aloka — Engineer & Design Thinker">

  <!-- Hero -->
<section class="min-h-[90vh] max-w-5xl mx-auto px-6 flex flex-col justify-center relative">

  <div class="absolute top-0 right-0 w-px h-full opacity-10" style="background: var(--royal);"></div>

  <div class="flex flex-col lg:flex-row items-center justify-between gap-12">

    <!-- Left: text -->
    <div class="max-w-xl w-full">
      <p class="section-label mb-6 animate-on-scroll">Engineer · Designer · Builder</p>

      <h1 class="font-display text-5xl md:text-7xl font-extrabold leading-[1.05] tracking-tight mb-8 animate-on-scroll" style="animation-delay: 0.1s;">
        Anindita Sarker Aloka
      </h1>

      <div class="h-1 w-12 mb-8 animate-on-scroll" style="background: var(--crimson); animation-delay: 0.15s;"></div>

      <p class="font-body text-lg leading-relaxed opacity-70 mb-10 animate-on-scroll" style="animation-delay: 0.2s;">
        I work across the boundaries of renewable energy systems, electronics, and design — not despite the breadth, but because of it. The connections between disciplines are where interesting things happen.
      </p>

      <div class="flex flex-wrap gap-4 animate-on-scroll" style="animation-delay: 0.3s;">
        <a href="/projects"
           class="font-display font-semibold text-sm px-6 py-3 transition-all duration-200 hover:opacity-80"
           style="background: var(--royal); color: white;">
          View Projects →
        </a>
        <a href="/about"
           class="font-display font-semibold text-sm px-6 py-3 transition-all duration-200 hover:opacity-70"
           style="border: 1px solid var(--border);">
          About Me
        </a>
      </div>
    </div>

    <!-- Right: hex photo — shows on all sizes, stacks below on mobile -->
    <div class="shrink-0">
      <div class="hex-hero-wrap">
        <div class="hex-hero-ring"></div>
        <div class="hex-hero">
          <img src="/Profile Picture.png" alt="Anindita Sarker Aloka" />
        </div>
      </div>
    </div>

  </div>
</section>

  <!-- Featured Projects -->
  {projects.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 py-20">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="section-label mb-3">Selected work</p>
          <h2 class="font-display text-3xl font-bold">Featured Projects</h2>
        </div>
        <a href="/projects" class="font-mono text-xs opacity-50 hover:opacity-100 transition-opacity hidden md:block">
          All projects →
        </a>
      </div>

      <div class="grid gap-6">
        {projects.map((project, i) => (
          <a href={`/projects/${project.slug}`}
             class="group block p-6 border transition-all duration-300 hover:border-opacity-100 hover:translate-y-[-2px] animate-on-scroll"
             style={`border-color: var(--border); animation-delay: ${i * 0.1}s;`}>
            <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex flex-wrap gap-2 mb-3">
                  {project.data.domain.map((d: string) => (
                    <span class={tagClass[d] || 'tag'}>{d}</span>
                  ))}
                </div>
                <h3 class="font-display text-xl font-bold mb-2 group-hover:opacity-70 transition-opacity">
                  {project.data.title}
                </h3>
                <p class="font-body text-sm leading-relaxed opacity-60">{project.data.description}</p>
              </div>
              <span class="font-mono text-xs opacity-30 group-hover:opacity-70 transition-opacity shrink-0 mt-1">
                {new Date(project.data.date).getFullYear()}
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Philosophy strip -->
  <section class="border-y py-16" style="border-color: var(--border); background-color: var(--bg-surface);">
    <div class="max-w-5xl mx-auto px-6">
      <blockquote class="font-display text-2xl md:text-3xl font-semibold leading-relaxed max-w-3xl animate-on-scroll">
        <span class="opacity-30 text-5xl leading-none">"</span>
        Jack of all trades, master of none — often times better than a master of one.
      </blockquote>
      <p class="font-mono text-xs opacity-30 mt-4 ml-6">The frame through which I work</p>
    </div>
  </section>

</BaseLayout>
<style>
  .hex-hero-wrap {
  position: relative;
  width: min(380px, 80vw);
  height: calc(min(380px, 80vw) * 1.13);
}
.hex-hero {
  position: absolute;
  top: 6px;
  left: 6px;
  width: calc(min(380px, 80vw) - 12px);
  height: calc((min(380px, 80vw) * 1.13) - 12px);
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  overflow: hidden;
  z-index: 2;
}
.hex-hero img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}
.hex-hero-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: min(380px, 80vw);
  height: calc(min(380px, 80vw) * 1.13);
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  background: #FCBA04;
  z-index: 1;
}
  .hex-hero {
    position: absolute;
    top: 6px;
    left: 6px;
    width: 288px;
    height: 326px;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    overflow: hidden;
    z-index: 2;
  }
  .hex-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .hex-hero-ring {
    position: absolute;
    top: 0;
    left: 0;
    width: 300px;
    height: 338px;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    background: #FCBA04;
    z-index: 1;
  }
</style>
---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Anindita Sarker Aloka">
  <section class="max-w-5xl mx-auto px-6 py-16 min-h-[70vh] flex flex-col justify-center">
    <p class="section-label mb-6">Get in touch</p>
    <h1 class="font-display text-5xl font-extrabold mb-6">Let's talk.</h1>
    <p class="font-body text-lg opacity-60 max-w-lg mb-12 leading-relaxed">
      I'm open to conversations about research collaborations, interesting engineering problems, and product design work. I'm not looking for generic outreach — but if you have something specific in mind, I'd like to hear it.
    </p>

    <div class="flex flex-col gap-4 mb-16">
      <a href="mailto:your@email.com"
         class="inline-flex items-center gap-4 group w-fit">
        <span class="font-mono text-xs opacity-40 w-20">Email</span>
        <span class="font-display text-lg font-semibold group-hover:opacity-60 transition-opacity">
          your@email.com →
        </span>
      </a>
      <a href="https://linkedin.com/in/YOUR_USERNAME" target="_blank" rel="noopener"
         class="inline-flex items-center gap-4 group w-fit">
        <span class="font-mono text-xs opacity-40 w-20">LinkedIn</span>
        <span class="font-display text-lg font-semibold group-hover:opacity-60 transition-opacity">
          linkedin.com/in/YOU →
        </span>
      </a>
      <a href="https://github.com/YOUR_USERNAME" target="_blank" rel="noopener"
         class="inline-flex items-center gap-4 group w-fit">
        <span class="font-mono text-xs opacity-40 w-20">GitHub</span>
        <span class="font-display text-lg font-semibold group-hover:opacity-60 transition-opacity">
          github.com/YOU →
        </span>
      </a>
    </div>

    <div class="h-px w-24" style="background: var(--crimson);"></div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Anindita Sarker Aloka">

  <section class="max-w-5xl mx-auto px-6 py-16 min-h-[70vh] relative z-10">
    <div class="max-w-2xl">
      <p class="section-label mb-6">Get in touch</p>
      <h1 class="font-display text-5xl font-extrabold mb-6">Let's talk.</h1>
      <p class="font-body text-lg opacity-60 max-w-lg mb-12 leading-relaxed">
        I'm open to conversations about research collaborations, interesting engineering problems, and product design work. If you have something specific in mind, I'd like to hear it.
      </p>

      <!-- Social links -->
      <div class="flex flex-col gap-4 mb-16">
        <a href="https://www.linkedin.com/in/aninditasarker-aloka/" target="_blank" rel="noopener"
           class="inline-flex items-center gap-4 group w-fit">
          <span class="font-mono text-xs opacity-40 w-20">LinkedIn</span>
          <span class="font-display text-lg font-semibold group-hover:opacity-60 transition-opacity">
            linkedin.com/in/YOU →
          </span>
        </a>
        <a href="https://github.com/Anindita-SA" target="_blank" rel="noopener"
           class="inline-flex items-center gap-4 group w-fit">
          <span class="font-mono text-xs opacity-40 w-20">GitHub</span>
          <span class="font-display text-lg font-semibold group-hover:opacity-60 transition-opacity">
            github.com/Anindita-SA →
          </span>
        </a>
      </div>

      <!-- Contact form -->
      <div class="border p-8" style="border-color: var(--border);">
        <p class="section-label mb-6">Send a message</p>

        <form id="contact-form" action="https://formspree.io/f/xreykvze" method="POST" class="flex flex-col gap-5">
          <div>
            <label class="font-mono text-xs opacity-50 block mb-2">Name</label>
            <input
              type="text"
              name="name"
              required
              placeholder="Your name"
              class="w-full px-4 py-3 font-body text-sm border outline-none transition-all focus:border-opacity-100"
              style="background: var(--bg-surface); border-color: var(--border); color: var(--text-primary);"
            />
          </div>

          <div>
            <label class="font-mono text-xs opacity-50 block mb-2">Email</label>
            <input
              type="email"
              name="email"
              required
              placeholder="your@email.com"
              class="w-full px-4 py-3 font-body text-sm border outline-none transition-all"
              style="background: var(--bg-surface); border-color: var(--border); color: var(--text-primary);"
            />
          </div>

          <div>
            <label class="font-mono text-xs opacity-50 block mb-2">Message</label>
            <textarea
              name="message"
              required
              rows="5"
              placeholder="What's on your mind?"
              class="w-full px-4 py-3 font-body text-sm border outline-none transition-all resize-none"
              style="background: var(--bg-surface); border-color: var(--border); color: var(--text-primary);"
            ></textarea>
          </div>

          <button
            type="submit"
            class="font-display font-semibold text-sm px-6 py-3 transition-all duration-200 hover:opacity-80 w-fit"
            style="background: var(--royal); color: white;"
          >
            Send message →
          </button>

          <p id="form-status" class="font-mono text-xs opacity-0 transition-opacity"></p>
        </form>
      </div>

      <div class="h-px w-24 mt-12" style="background: var(--crimson);"></div>
    </div>
  </section>
</BaseLayout>

<style>

  input:focus, textarea:focus {
    border-color: var(--royal) !important;
  }
  .dark input:focus, .dark textarea:focus {
    border-color: var(--amber) !important;
  }
</style>

<script is:inline>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const response = await fetch(form.action, {
      method: 'POST',
      body: data,
      headers: { 'Accept': 'application/json' }
    });

    if (response.ok) {
      status.textContent = '✓ Message sent — I\'ll get back to you soon.';
      status.style.opacity = '1';
      status.style.color = 'var(--royal)';
      form.reset();
    } else {
      status.textContent = '✗ Something went wrong. Try emailing directly.';
      status.style.opacity = '1';
      status.style.color = 'var(--crimson)';
    }
  });
</script>
